# ═══════════════════════════════════════════════════════════════════════════════
#  SISH — Konfigurimi për Supabase prodhim
# ═══════════════════════════════════════════════════════════════════════════════

# Direct connection (për migrime, schema changes — port 5432)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Pooled connection (për queries në runtime — port 6543, PgBouncer)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase API keys (për Storage + Realtime + Edge Functions)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJxxxxxxxxxxxxxxxxxxxxxx"

# Auth (i njëjtë si dev)
AUTH_SECRET="REPLACE_WITH_NEW_64_CHAR_RANDOM_STRING"
AUTH_TRUST_HOST="true"

# App
NEXT_PUBLIC_APP_URL="https://sish.app"
NEXT_PUBLIC_APP_NAME="SISH"
NODE_ENV="production"

# Security
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
SESSION_DURATION_HOURS="8"

# Storage paths
SISH_STORAGE_LOGOS_BUCKET="sish-logos"
SISH_STORAGE_DOCS_BUCKET="sish-patient-docs"
SISH_STORAGE_SIGS_BUCKET="sish-signatures"
SISH_STORAGE_BACKUPS_BUCKET="sish-backups"
